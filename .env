# ========== Environment & Server ==========
NODE_ENV=development
PORT=5000

# ========== Database ==========
MONGODB_URI=mongodb://localhost:27017/lms_db

# ========== JWT Secrets ==========
JWT_SECRET=your_super_secret_jwt_key_min_32_characters_long_2024
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_32_chars_2024
JWT_REFRESH_EXPIRES_IN=7d

# ========== Email Configuration (Gmail SMTP) ==========
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_specific_password

# ========== Cloudinary (Images, Videos, PDFs) ==========
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ========== Stripe Payment Integration ==========
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ========== OAuth (Google) ==========
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# ========== OAuth (GitHub) ==========
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:5000/api/v1/auth/github/callback

# ========== Frontend URL (CORS) ==========
FRONTEND_URL=http://localhost:3000

# ========== Business Logic Settings ==========
INSTRUCTOR_REVENUE_SHARE=70
CERTIFICATE_THRESHOLD=80

# ========== Logging ==========
LOG_LEVEL=debug
